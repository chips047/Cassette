{
    "open": {
        "curves": {
            "y_offset": {
                "keyframes":   [[0.0, -0.2], [1.0, 0.0]],
                "duration_ms": 500,
                "easing":      "bouncy"
            }
        },
        "bases": {
            "opacity_content":    1.0,
            "opacity_background": 1.0
        }
    },
    "close": {
        "curves": {
            "y_offset": {
                "keyframes":   [[0.0, 0.0], [1.0, 0.1]],
                "duration_ms": 300,
                "easing":      "ease_out_cubic"
            },
            "opacity_content": {
                "keyframes":   [[0.0, 1.0], [1.0, 0.0]],
                "duration_ms": 100,
                "easing":      "linear"
            },
            "opacity_background": {
                "keyframes":   [[0.0, 1.0], [1.0, 0.0]],
                "duration_ms": 100,
                "easing":      "linear",
                "finished":    "really_close"
            }
        }
    },
    "disturb": {
        "curves": {
            "scale": {
                "keyframes":   [[0.0, 1.0], [0.5, 1.05], [1.0, 1.0]],
                "duration_ms": 320,
                "easing":      "linear"
            },
            "rotation_z": {
                "keyframes":   [[0.0, 0.0], [0.5, {"period": [[-30, -15], [15, 30]]}], [1.0, 0.0]],
                "duration_ms": 900,
                "easing":      "very_bouncy"
            }
        }
    },
    "sounds": {
        "open":    ["Packs/Classic/Open"],
        "close":   ["Packs/Classic/Close"],
        "disturb": ["Packs/Classic/Disturbe"]
    }
}
